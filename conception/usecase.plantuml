@startuml
left to right direction
skinparam packageStyle rectangle

actor "Utilisateur" as user
actor "Super Admin" as admin
actor "Coach" as coach
actor "Parent" as parent
actor "Systeme Stripe" as stripe << Externe >>

admin -up-|> user
coach -up-|> user
parent -up-|> user

usecase "S'authentifier" as UC_Auth

'--- Use Cases Super Admin ---
usecase "Gerer les comptes" as UC_ManageUsers
usecase "Creer compte" as UC_CreateUser
usecase "Editer compte" as UC_EditUser
usecase "Supprimer compte" as UC_DeleteUser

usecase "Gerer les enfants (Joueurs)" as UC_ManagePlayers
usecase "Creer joueur" as UC_CreatePlayer
usecase "Editer joueur" as UC_EditPlayer
usecase "Supprimer joueur" as UC_DeletePlayer

usecase "Gerer Categories et Groupes" as UC_ManageStruct
usecase "Creer categorie/groupe" as UC_CreateStruct
usecase "Editer categorie/groupe" as UC_EditStruct
usecase "Supprimer categorie/groupe" as UC_DeleteStruct

usecase "Affecter joueur a une Categorie" as UC_AssignPlayerCat
usecase "Assigner Coach a un Groupe" as UC_AssignCoach
usecase "Consulter les paiements" as UC_ViewPay
usecase "Envoyer des notifications" as UC_SendNotif

'--- Use Cases Coach ---
usecase "Assigner joueur a un Groupe" as UC_AssignPlayerGrp
usecase "Gerer le planning (Seances)" as UC_ManageSessions
usecase "Creer seance" as UC_CreateSession
usecase "Editer seance" as UC_EditSession
usecase "Supprimer seance" as UC_DeleteSession

usecase "Faire l'appel (Presences)" as UC_Attendance
usecase "Evaluer un joueur" as UC_Evaluate

'--- Use Cases Parent ---
usecase "Consulter suivi et planning" as UC_ViewProgress
usecase "Payer en ligne" as UC_PayOnline

'--- Extend ---
usecase "Saisir motif d'absence" as UC_AbsenceReason

' Relations include (auth)
UC_ManageUsers ..> UC_Auth : <<include>>
UC_ManagePlayers ..> UC_Auth : <<include>>
UC_ManageStruct ..> UC_Auth : <<include>>
UC_AssignPlayerCat ..> UC_Auth : <<include>>
UC_AssignCoach ..> UC_Auth : <<include>>
UC_ViewPay ..> UC_Auth : <<include>>
UC_SendNotif ..> UC_Auth : <<include>>

UC_AssignPlayerGrp ..> UC_Auth : <<include>>
UC_ManageSessions ..> UC_Auth : <<include>>
UC_Attendance ..> UC_Auth : <<include>>
UC_Evaluate ..> UC_Auth : <<include>>

UC_ViewProgress ..> UC_Auth : <<include>>
UC_PayOnline ..> UC_Auth : <<include>>

' CRUD include
UC_ManageUsers ..> UC_CreateUser : <<include>>
UC_ManageUsers ..> UC_EditUser : <<include>>
UC_ManageUsers ..> UC_DeleteUser : <<include>>

UC_ManagePlayers ..> UC_CreatePlayer : <<include>>
UC_ManagePlayers ..> UC_EditPlayer : <<include>>
UC_ManagePlayers ..> UC_DeletePlayer : <<include>>

UC_ManageStruct ..> UC_CreateStruct : <<include>>
UC_ManageStruct ..> UC_EditStruct : <<include>>
UC_ManageStruct ..> UC_DeleteStruct : <<include>>

UC_ManageSessions ..> UC_CreateSession : <<include>>
UC_ManageSessions ..> UC_EditSession : <<include>>
UC_ManageSessions ..> UC_DeleteSession : <<include>>

' Extend
UC_AbsenceReason .up.> UC_Attendance : <<extend>>

' Acteurs -> Use cases
admin --> UC_ManageUsers
admin --> UC_ManagePlayers
admin --> UC_ManageStruct
admin --> UC_AssignPlayerCat
admin --> UC_AssignCoach
admin --> UC_ViewPay
admin --> UC_SendNotif

coach --> UC_AssignPlayerGrp
coach --> UC_ManageSessions
coach --> UC_Attendance
coach --> UC_Evaluate

parent --> UC_ViewProgress
parent --> UC_PayOnline

' Stripe
UC_PayOnline <-- stripe

@enduml